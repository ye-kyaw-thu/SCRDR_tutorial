digraph SCRDR_Weather_Learning {
    // Quality settings for high-resolution PNG/PDF output
    graph [rankdir=TB, nodesep=0.5, ranksep=0.4, fontname="Segoe UI, Arial", fontsize=12, splines=polyline];
    node [shape=none, fontname="Segoe UI, Arial", fontsize=11];
    edge [color="#5F6368", fontname="Segoe UI, Arial", fontsize=10];

    // Data Rows as Inputs from weather_demo.log
    subgraph cluster_data {
        label="Input Data Stream (Errors Found)";
        style=dotted;
        Row1 [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="8" bgcolor="#E8F0FE">
                <tr><td><b>Row 1</b></td></tr>
                <tr><td>Outlook: Sunny<br/>Windy: False</td></tr>
                <tr><td><i>Actual: Swim</i></td></tr>
            </table>
        >];
        Row2 [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="8" bgcolor="#E8F0FE">
                <tr><td><b>Row 2</b></td></tr>
                <tr><td>Outlook: Sunny<br/>Windy: True</td></tr>
                <tr><td><i>Actual: Stay-In</i></td></tr>
            </table>
        >];
        Row4 [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="8" bgcolor="#E8F0FE">
                <tr><td><b>Row 4</b></td></tr>
                <tr><td>Outlook: Rain<br/>Windy: False</td></tr>
                <tr><td><i>Actual: Walk</i></td></tr>
            </table>
        >];
        Row7 [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="8" bgcolor="#E8F0FE">
                <tr><td><b>Row 7</b></td></tr>
                <tr><td>Outlook: Overcast<br/>Windy: True</td></tr>
                <tr><td><i>Actual: Walk</i></td></tr>
            </table>
        >];
    }

    // The Evolving Model Structure based on weather_demo.json
    subgraph cluster_model {
        label="RDR Model Evolution";
        Root [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="8" bgcolor="#F1F3F4">
                <tr><td><b>Root Node</b></td></tr>
                <tr><td>Conclusion: Unknown</td></tr>
            </table>
        >];
        Rule1 [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="8" bgcolor="#D2E3FC">
                <tr><td><b>Rule 1 (Refinement)</b></td></tr>
                <tr><td>Windy == False</td></tr>
                <tr><td>Conclusion: Swim</td></tr>
            </table>
        >];
        Rule2 [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="8" bgcolor="#D2E3FC">
                <tr><td><b>Rule 2 (Alternative)</b></td></tr>
                <tr><td>Windy == True</td></tr>
                <tr><td>Conclusion: Stay-In</td></tr>
            </table>
        >];
        Rule3 [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="8" bgcolor="#FFF4E5">
                <tr><td><b>Rule 3 (Refinement of 1)</b></td></tr>
                <tr><td>Outlook == Rain</td></tr>
                <tr><td>Conclusion: Walk</td></tr>
            </table>
        >];
        Rule4 [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="8" bgcolor="#FFF4E5">
                <tr><td><b>Rule 4 (Refinement of 2)</b></td></tr>
                <tr><td>Outlook == Overcast</td></tr>
                <tr><td>Conclusion: Walk</td></tr>
            </table>
        >];
    }

    // Expert Intervention Point
    Expert [label="EXPERT INTERVENTION\n(Knowledge Acquisition)", shape=hexagon, style="filled,bold", fillcolor="#FFF4E5", color="#E37400", fontsize=12];

    // Flow for Row 1
    Row1 -> Root [label="1. Predict"];
    Root -> Expert [label="2. ERROR: Expected 'Swim'\nPredicted 'Unknown'"];
    Expert -> Rule1 [label="3. Add Refinement\nto Root"];

    // Flow for Row 2
    Row2 -> Rule1 [label="4. Evaluates False"];
    Rule1 -> Expert [label="5. ERROR: Predicted 'Unknown'\n(Fall back to Root)"];
    Expert -> Rule2 [label="6. Add Alternative\nto Rule 1"];

    // Flow for Row 4
    Row4 -> Rule1 [label="7. Evaluates True"];
    Rule1 -> Expert [label="8. ERROR: Predicted 'Swim'\nExpected 'Walk'"];
    Expert -> Rule3 [label="9. Add Refinement\nto Rule 1"];

    // Flow for Row 7
    Row7 -> Rule2 [label="10. Evaluates True"];
    Rule2 -> Expert [label="11. ERROR: Predicted 'Stay-In'\nExpected 'Walk'"];
    Expert -> Rule4 [label="12. Add Refinement\nto Rule 2"];

    // Final result
    Rule4 -> Final [label="Final Accuracy: 1.0", style=bold, color="#137333"];
    Final [label="Fully Built Model\n(weather_demo.json)", shape=note, style="filled,bold", fillcolor="#E6F4EA", color="#137333"];
}

