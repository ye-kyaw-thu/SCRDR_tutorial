digraph SCRDR_Students_Adjusted {
    // Quality settings for high-resolution PNG/PDF output
    graph [rankdir=TB, nodesep=0.5, ranksep=0.4, fontname="Segoe UI, Arial", fontsize=12, splines=polyline];
    node [shape=none, fontname="Segoe UI, Arial", fontsize=11];
    edge [color="#5F6368", fontname="Segoe UI, Arial", fontsize=10];

    // Data Rows as Inputs from demo.log
    subgraph cluster_data {
        label="Input Data Stream";
        style=dotted;
        Row1 [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="8" bgcolor="#E8F0FE">
                <tr><td><b>Row 1</b></td></tr>
                <tr><td>Hours: 2<br/>Attend: 40%</td></tr>
                <tr><td><i>Actual: Fail</i></td></tr>
            </table>
        >];
        Row2 [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="8" bgcolor="#E8F0FE">
                <tr><td><b>Row 2</b></td></tr>
                <tr><td>Hours: 15<br/>Attend: 95%</td></tr>
                <tr><td><i>Actual: Pass</i></td></tr>
            </table>
        >];
        Row5 [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="8" bgcolor="#E8F0FE">
                <tr><td><b>Row 5</b></td></tr>
                <tr><td>Hours: 8<br/>Attend: 45%</td></tr>
                <tr><td><i>Actual: Fail</i></td></tr>
            </table>
        >];
    }

    // The Evolving Model Structure based on students_rules_demo.json
    subgraph cluster_model {
        label="RDR Model Evolution";
        Root [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="8" bgcolor="#F1F3F4">
                <tr><td><b>Root Node</b></td></tr>
                <tr><td>Conclusion: Unknown</td></tr>
            </table>
        >];
        Rule1 [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="8" bgcolor="#D2E3FC">
                <tr><td><b>Refinement 1</b></td></tr>
                <tr><td>Hours_Studied &lt; 6</td></tr>
                <tr><td>Conclusion: Fail</td></tr>
            </table>
        >];
        Rule2 [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="8" bgcolor="#D2E3FC">
                <tr><td><b>Alternative 2</b></td></tr>
                <tr><td>Attendance_Pct &gt; 50</td></tr>
                <tr><td>Conclusion: Pass</td></tr>
            </table>
        >];
        Rule3 [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="8" bgcolor="#D2E3FC">
                <tr><td><b>Alternative 3</b></td></tr>
                <tr><td>Attendance_Pct &lt; 50</td></tr>
                <tr><td>Conclusion: Fail</td></tr>
            </table>
        >];
    }

    // Expert Intervention Point
    Expert [label="EXPERT INTERVENTION\n(Knowledge Acquisition)", shape=hexagon, style="filled,bold", fillcolor="#FFF4E5", color="#E37400", fontsize=12];

    // Flow for Row 1
    Row1 -> Root [label="1. Predict"];
    Root -> Expert [label="2. ERROR: Expected 'Fail'\nPredicted 'Unknown'"];
    Expert -> Rule1 [label="3. Add Refinement\nto Root"];

    // Flow for Row 2
    Row2 -> Rule1 [label="4. Evaluates False"];
    Rule1 -> Expert [label="5. ERROR: Predicted 'Unknown'\n(End of branch)"];
    Expert -> Rule2 [label="6. Add Alternative\nto Rule 1"];

    // Flow for Row 5
    Row5 -> Rule2 [label="7. Evaluates False"];
    Rule2 -> Expert [label="8. ERROR: Predicted 'Unknown'\n(End of branch)"];
    Expert -> Rule3 [label="9. Add Alternative\nto Rule 2"];

    // Result
    Rule3 -> Final [label="Final Accuracy: 1.0", style=bold, color="#137333"];
    Final [label="Fully Built Model\n(students_rules_demo.json)", shape=note, style="filled,bold", fillcolor="#E6F4EA", color="#137333"];
}

